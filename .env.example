# =============================================================================
# AMORIA - Virtual Human dengan Jiwa
# =============================================================================

# =============================================================================
# TELEGRAM BOT
# =============================================================================
# Dapatkan dari @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# =============================================================================
# AI DEEPSEEK
# =============================================================================
# Dapatkan dari platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# =============================================================================
# ADMIN
# =============================================================================
# ID Telegram admin (bisa didapat dari @userinfobot)
ADMIN_ID=0

# =============================================================================
# DATABASE
# =============================================================================
DB_PATH=data/amoria.db
DB_TYPE=sqlite
DB_POOL_SIZE=5
DB_TIMEOUT=30

# =============================================================================
# AI CONFIGURATION
# =============================================================================
AI_TEMPERATURE=0.95
AI_MAX_TOKENS=4000
AI_TIMEOUT=45
AI_MODEL=deepseek-chat

# =============================================================================
# RESPONSE CONFIGURATION
# =============================================================================
MIN_RESPONSE_LENGTH=1000
MAX_RESPONSE_LENGTH=4000
MIN_SENTENCES=4
MAX_SENTENCES=12

# =============================================================================
# MEMORY CONFIGURATION
# =============================================================================
WORKING_MEMORY_SIZE=1000
LONG_TERM_MEMORY_SIZE=10000
EMOTIONAL_MEMORY_SIZE=500
MEMORY_DIR=data/memory

# =============================================================================
# LEVEL & INTIMACY
# =============================================================================
LEVEL_1_TARGET=7
LEVEL_2_TARGET=15
LEVEL_3_TARGET=25
LEVEL_4_TARGET=35
LEVEL_5_TARGET=45
LEVEL_6_TARGET=55
LEVEL_7_TARGET=65
LEVEL_8_TARGET=75
LEVEL_9_TARGET=85
LEVEL_10_TARGET=95
LEVEL_11_MIN=96
LEVEL_11_MAX=125
LEVEL_12_MIN=126
LEVEL_12_MAX=135

# =============================================================================
# STAMINA
# =============================================================================
STAMINA_BOT_START=100
STAMINA_USER_START=100
STAMINA_DROP_FIRST=30
STAMINA_DROP_SECOND=50
STAMINA_DROP_THIRD=70
STAMINA_RECOVERY_PER_HOUR=5

# =============================================================================
# SESSION & IDENTITY
# =============================================================================
SESSION_DIR=data/sessions
SESSION_RETENTION_DAYS=30
MAX_CHARACTERS_PER_ROLE=10

# =============================================================================
# FEATURE TOGGLES
# =============================================================================
SEXUAL_CONTENT_ENABLED=true
THREESOME_ENABLED=true
PUBLIC_RISK_ENABLED=true
AFTERCARE_ENABLED=true
FLASHBACK_ENABLED=true
SIXTH_SENSE_ENABLED=true

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_DIR=data/logs

# =============================================================================
# BACKUP
# =============================================================================
BACKUP_ENABLED=true
BACKUP_INTERVAL=3600
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=data/backups
BACKUP_S3_BUCKET=

# =============================================================================
# WEBHOOK (Railway)
# =============================================================================
PORT=8080
WEBHOOK_PATH=/webhook
RAILWAY_PUBLIC_DOMAIN=
